{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "An agile task or issue in the workspace tracker",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the task"
        },
        "title": {
          "type": "string",
          "description": "The visual title of the task"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of what is required for the task"
        },
        "status": {
          "type": "string",
          "enum": ["backlog", "in_progress", "completed"],
          "description": "The current workflow status on the Kanban board"
        },
        "storyPoints": {
          "type": "number",
          "description": "Story points indicating task complexity and effort"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Priority tier of the task"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the task was originally registered"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the task was most recently edited"
        }
      },
      "required": ["id", "title", "status"]
    }
  },
  "firestore": {
    "tasks": {
      "schema": "Task",
      "description": "Kanban board tasks managed by the agile project tracker"
    }
  }
}
